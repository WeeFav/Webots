<?xml version="1.0" ?>
<robot name="My robot">
    <webots>
        <device reference="cam0" type="Camera">
            <ros>
                <topicName>/vehicle/camera</topicName>
                <alwaysOn>true</alwaysOn>
            </ros>
        </device>
        <device reference="lidar" type="Lidar">
            <ros>
                <topicName>/vehicle/lidar</topicName>
                <alwaysOn>true</alwaysOn>
            </ros>
        </device>
        <plugin type="my_package.my_robot_driver.TeslaDriver" />
    </webots>
</robot>